[gpg]
  format = ssh

[gpg "ssh"]
  # macOS: sudo ln -s /Applications/1Password.app/Contents/MacOS/op-ssh-sign /usr/local/bin/op-ssh-sign 
  program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign

[commit]
  gpgsign = true

[core]
  editor = nvim -u ~/.config/nvim/disable-editorconfig.lua

[credential "https://git.rgst.io"]
  # macOS: Note, Xcode CLT may override this
  helper = cache --timeout 21600
  helper = oauth

[credential "https://github.com"]
  helper = 
  helper = !gh auth git-credential

[credential "https://gist.github.com"]
  helper = 
  helper = !gh auth git-credential
